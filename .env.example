# Copy this file to `.env.local` and fill in real values. `.env.local` is gitignored.
#
#   cp .env.example .env.local
#
# Load it before running the pipeline (Git Bash):
#   set -a; source .env.local; set +a
#
# Or inline for a single command:
#   HF_TOKEN=hf_xxx python pipeline.py clean --fineweb-shards 10 --workers 4

# HuggingFace token. Overrides the cached token in ~/.cache/huggingface/token.
# Needs role WRITE if you will push the model (Phase 6); READ is enough to stream data.
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: move the data directory off the system drive (default: ./data)
# SLM_DATA_ROOT=D:/slm-125m-data
